DASHSCOPE_API_KEY=sk-xxx
QWEN_MODEL=qwen-plus
QWEN_MODEL_FAST=qwen-turbo
QWEN_EMBEDDING_MODEL=text-embedding-v3
MATCH_THRESHOLD=60
MAX_INTERVIEW_ROUNDS=10
DATABASE_URL=sqlite:///./data/app.db
CHROMA_PATH=./data/chroma

# Docker / 子路径部署（服务器 Nginx /airecruit/ 时填写）
# PUBLIC_BASE_PATH=/airecruit
# DATABASE_URL=sqlite:////app/data/app.db
# CHROMA_PATH=/app/data/chroma

# Volcengine openspeech (optional — voice mode)
VOLC_SPEECH_API_KEY=
VOLC_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
VOLC_TTS_RESOURCE_ID=seed-tts-2.0
VOLC_TTS_SPEAKER_TECH=zh_male_jingqiangkanye_moon_bigtts
VOLC_TTS_SPEAKER_HR=zh_female_vv_uranus_bigtts

# LLM Harness（调用日志 / timeout / 截断）
LLM_LOG_ENABLED=true
LLM_LOG_PATH=data/llm_calls.jsonl
LLM_TIMEOUT_DEFAULT=30
LLM_TIMEOUT_REPORT=60
LLM_TIMEOUT_STREAM=120
LLM_MAX_SYSTEM_CHARS=8000
LLM_MAX_USER_CHARS=12000
LLM_STRUCTURED_MAX_RETRIES=2
LLM_TRACE_BACKEND=none
